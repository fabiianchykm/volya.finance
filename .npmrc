# next-auth@5 beta ще декларує peer next@"14 || 15", а проєкт на next@16.
# Локальні node_modules ставились із legacy-peer-deps, тож `next build` працює.
# App Hosting робить чистий `npm ci`, який без цього падає на ERESOLVE (exit 51).
# Тримаємо тут, поки next-auth не оновить peer-діапазон під next@16.
legacy-peer-deps=true
