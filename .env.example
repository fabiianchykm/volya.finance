# ─── Ukasko API ───────────────────────────────────────────────
# Креди партнерського кабінету Ukasko (НЕ комітити реальні значення!)
UKASKO_EMAIL=your-ukasko-email@example.com
UKASKO_PASSWORD=your-ukasko-password
# dev → devconnect.ukasko.ua (тест), будь-що інше / порожньо → connect.ukasko.ua (прод)
UKASKO_ENV=dev

# ─── App URL ──────────────────────────────────────────────────
# Публічний URL застосунку. Зашивається у білд → після зміни потрібен новий деплой.
# Локально: http://localhost:3000   Прод: https://your-domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Додаткові дозволені origin'и для захисту API від cross-site (через кому).
# NEXT_PUBLIC_APP_URL та AUTH_URL дозволені автоматично; localhost — лише в dev.
# Тут варто додати preview-домени деплою, напр.:
# ALLOWED_ORIGINS=https://preview-abc.vercel.app,https://staging.your-domain
ALLOWED_ORIGINS=

# ─── NextAuth (Auth.js v5) ────────────────────────────────────
# Базовий URL для callback-ів. Має збігатися з реальним доменом.
AUTH_URL=http://localhost:3000
# Згенерувати: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── База даних (Postgres: Neon / Supabase) ───────────────────
# Зберігає оформлені поліси, привʼязані до email. Без цієї змінної фіча «Мої
# поліси» просто вимкнена (сайт працює). Використовуй POOLED-конект (pgBouncer):
#   Neon:     postgresql://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/db?sslmode=require
#   Supabase: postgresql://postgres.<ref>:pass@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ─── Telegram (заявки КАСКО) ──────────────────────────────────
# Заявки на КАСКО (телефон + дані авто) надсилаються менеджеру в Telegram.
# Без цих змінних форма КАСКО повертає помилку (заявку нема куди слати).
# 1) Створи бота через @BotFather → отримай токен.
# 2) chat_id: напиши боту, відкрий https://api.telegram.org/bot<token>/getUpdates
#    і візьми chat.id (для групи — від'ємне число), або скористайся @getidsbot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
